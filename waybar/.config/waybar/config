{
  "layer": "top",
  "position": "bottom",
  "height": 28,
  "spacing": 0,
  "exclusive": true,

  "modules-left": [
    "sway/workspaces",
    "sway/mode"
  ],

  "modules-center": [
    "mpris"
  ],

  "modules-right": [
    "network",
    "cpu",
    "temperature",
    "memory",
    "pulseaudio",
    "battery",
    "clock"
  ],

  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "format": "{name}"
  },

  "sway/mode": {
    "format": "  {}"
  },

  "mpris": {
    "format": "{artist} – {title}",
    "format-paused": "{artist} – {title} [paused]",
    "player-icons": {
      "default": "▶",
      "spotify": ""
    },
    "status-icons": {
      "paused": ""
    },
    "max-length": 60,
    "tooltip": false
  },

  "cpu": {
    "format": "CPU {usage}%",
    "interval": 2,
    "tooltip": false
  },

  "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon0/temp1_input",
    "format": "{temperatureC}°C",
    "critical-threshold": 85,
    "interval": 5,
    "tooltip": false
  },

  "memory": {
    "format": "MEM {used:.1f}/{total:.1f}G",
    "interval": 5,
    "tooltip": false
  },

  "network": {
    "format-wifi": "{essid} {signalStrength}%",
    "format-ethernet": "{ipaddr}",
    "format-disconnected": "disconnected",
    "interval": 10,
    "tooltip": false
  },

  "pulseaudio": {
    "format": "VOL {volume}%",
    "format-muted": "MUTED",
    "on-click": "pavucontrol",
    "tooltip": false,
    "signal": 8
  },

  "battery": {
    "format": "BAT {capacity}%",
    "format-charging": "BAT {capacity}% +",
    "format-full": "BAT full",
    "states": {
      "warning": 30,
      "critical": 15
    },
    "interval": 30,
    "tooltip": false
  },

  "clock": {
    "format": "{:%a %b %d  %H:%M:%S}",
    "interval": 1,
    "tooltip": false
  }
}
